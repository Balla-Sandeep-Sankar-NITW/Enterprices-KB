# ─────────────────────────────────────────
# Application
# ─────────────────────────────────────────
APP_NAME="Enterprise Knowledge Base"
APP_VERSION="2.0.0"
DEBUG=True
SECRET_KEY=change-this-to-a-random-string-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────
# Neon PostgreSQL
# Sign up: https://neon.tech (free)
# Dashboard → Your Project → Connection Details → Copy connection string
# ─────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─────────────────────────────────────────
# Pinecone (Vector Database)
# Sign up: https://pinecone.io (free)
# Console → API Keys → Copy key
# ─────────────────────────────────────────
PINECONE_API_KEY=pcsk_xxxxxxxxxxxxxxxxxxxx
PINECONE_INDEX_NAME=enterprise-kb
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ─────────────────────────────────────────
# Voyage AI (Embeddings - replaces sentence-transformers)
# Sign up: https://voyageai.com (free - 50M tokens/month)
# Dashboard → API Keys → Create key
# ─────────────────────────────────────────
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxx
VOYAGE_EMBEDDING_MODEL=voyage-2

# ─────────────────────────────────────────
# OpenRouter (LLM)
# Sign up: https://openrouter.ai
# Dashboard → API Keys → Create key
# Free models: google/gemma-2-9b-it:free  or  meta-llama/llama-3-8b-instruct:free
# ─────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=mistralai/mistral-7b-instruct

# ─────────────────────────────────────────
# Gmail SMTP (Email - same as before, zero CPU)
# Step 1: Enable 2FA at https://myaccount.google.com/security
# Step 2: Generate App Password at https://myaccount.google.com/apppasswords
# Step 3: Paste the 16-char app password below
# ─────────────────────────────────────────
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_FROM=your-email@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# ─────────────────────────────────────────
# File Storage
# ─────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,txt,xlsx

# ─────────────────────────────────────────
# First Admin (auto-created on first startup)
# ─────────────────────────────────────────
FIRST_ADMIN_EMAIL=admin@company.com
FIRST_ADMIN_PASSWORD=Admin@123456
